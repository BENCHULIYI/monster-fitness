<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
<title>怪兽训练计划</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0a0a0a">
<style>
/* ===== CSS Variables & Reset ===== */
:root {
  --bg-primary: #0a0a0a;
  --bg-secondary: #111111;
  --bg-card: #1a1a1a;
  --bg-card-hover: #222222;
  --border-green: #00ff6a;
  --border-orange: #ff6a00;
  --text-primary: #e0e0e0;
  --text-secondary: #888888;
  --text-green: #00ff6a;
  --text-orange: #ff6a00;
  --glow-green: 0 0 10px rgba(0,255,106,0.3);
  --glow-orange: 0 0 10px rgba(255,106,0,0.3);
  --nav-height: 60px;
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html,body { height:100%; overflow:hidden; }
body {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: var(--bg-primary); color: var(--text-primary);
  padding-top: var(--safe-top); padding-bottom: var(--safe-bottom);
}
/* ===== App Container ===== */
.app-container { display:flex; flex-direction:column; height:100%; max-width:480px; margin:0 auto; position:relative; }
/* ===== Header ===== */
.app-header {
  padding: 12px 16px 8px; background: var(--bg-primary);
  border-bottom: 1px solid #1a1a1a; display:flex; align-items:center; justify-content:space-between;
  position: sticky; top: 0; z-index: 100;
}
.app-title { font-size:18px; font-weight:700; color:var(--text-green); text-shadow:0 0 10px rgba(0,255,106,0.5); letter-spacing:1px; }
.app-subtitle { font-size:11px; color:var(--text-secondary); margin-top:2px; }
.header-right { display:flex; gap:12px; align-items:center; }
.header-btn { background:none; border:none; color:var(--text-green); cursor:pointer; padding:4px; }
/* ===== Pages ===== */
.page { display:none; flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:0 0 20px; }
.page.active { display:block; }
/* ===== Onboarding ===== */
.onboarding-page {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  min-height:100vh; padding:30px 24px; text-align:center;
}
.onboarding-page h1 { font-size:28px; color:var(--text-green); margin-bottom:8px; text-shadow:0 0 20px rgba(0,255,106,0.5); }
.onboarding-page p { color:var(--text-secondary); margin-bottom:30px; line-height:1.6; }
.onboarding-step { width:100%; max-width:360px; margin-bottom:24px; text-align:left; }
.onboarding-step h3 { color:var(--text-green); margin-bottom:12px; font-size:15px; }
.equip-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
.equip-card {
  background:var(--bg-card); border:2px solid #333; border-radius:12px;
  padding:14px 8px; text-align:center; cursor:pointer; transition:all 0.2s;
}
.equip-card:active { transform:scale(0.95); }
.equip-card.selected { border-color:var(--text-green); box-shadow:var(--glow-green); background:#1a2a1a; }
.equip-icon { font-size:28px; margin-bottom:6px; }
.equip-name { font-size:12px; color:var(--text-primary); }
.goal-options { display:flex; flex-direction:column; gap:10px; }
.goal-card {
  background:var(--bg-card); border:2px solid #333; border-radius:12px;
  padding:14px 16px; display:flex; align-items:center; gap:12px; cursor:pointer; transition:all 0.2s;
}
.goal-card.selected { border-color:var(--text-green); box-shadow:var(--glow-green); }
.goal-icon { font-size:24px; }
.goal-text h4 { font-size:14px; color:var(--text-primary); }
.goal-text p { font-size:11px; color:var(--text-secondary); margin:0; }
.freq-options { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; }
.freq-card {
  background:var(--bg-card); border:2px solid #333; border-radius:10px;
  padding:12px 6px; text-align:center; cursor:pointer; transition:all 0.2s;
}
.freq-card.selected { border-color:var(--text-green); box-shadow:var(--glow-green); }
.freq-num { font-size:22px; font-weight:700; color:var(--text-green); }
.freq-label { font-size:10px; color:var(--text-secondary); }
.btn-primary {
  background:linear-gradient(135deg,#00ff6a,#00cc55); color:#000; border:none;
  border-radius:25px; padding:14px 40px; font-size:16px; font-weight:700;
  cursor:pointer; margin-top:20px; transition:all 0.2s; letter-spacing:1px;
}
.btn-primary:active { transform:scale(0.96); }
/* ===== Today Page (Home) ===== */
.today-hero {
  background: linear-gradient(180deg, #0f1f0f 0%, var(--bg-primary) 100%);
  padding: 20px 16px 16px; margin-bottom: 4px;
}
.today-date { font-size:12px; color:var(--text-secondary); margin-bottom:4px; }
.today-greeting { font-size:22px; font-weight:700; margin-bottom:4px; }
.today-greeting span { color:var(--text-green); }
.today-streak { display:inline-flex; align-items:center; gap:4px; background:rgba(0,255,106,0.1); border:1px solid rgba(0,255,106,0.3); border-radius:20px; padding:4px 12px; font-size:12px; color:var(--text-green); margin-top:8px; }
/* Quick Stats Row */
.quick-stats { display:flex; gap:8px; padding:0 16px; margin-bottom:16px; }
.quick-stat {
  flex:1; background:var(--bg-card); border-radius:12px; padding:12px 10px;
  text-align:center; border:1px solid #222;
}
.quick-stat-value { font-size:20px; font-weight:700; color:var(--text-green); }
.quick-stat-label { font-size:10px; color:var(--text-secondary); margin-top:2px; }
/* Today Workout Card */
.today-workout-card {
  margin:0 16px 16px; background:var(--bg-card); border-radius:16px;
  border:1px solid #222; overflow:hidden;
}
.today-workout-header {
  padding:14px 16px; display:flex; justify-content:space-between; align-items:center;
  border-bottom:1px solid #222;
}
.today-workout-title { font-size:15px; font-weight:600; }
.today-workout-tag {
  font-size:11px; padding:3px 10px; border-radius:20px; font-weight:600;
}
.tag-training { background:rgba(0,255,106,0.15); color:var(--text-green); border:1px solid rgba(0,255,106,0.3); }
.tag-rest { background:rgba(255,106,0,0.15); color:var(--text-orange); border:1px solid rgba(255,106,0,0.3); }
.today-exercise-list { padding:8px 0; }
.today-exercise-item {
  display:flex; align-items:center; padding:10px 16px; gap:12px;
  border-bottom:1px solid #1a1a1a;
}
.today-exercise-item:last-child { border-bottom:none; }
.exercise-checkbox {
  width:22px; height:22px; border-radius:50%; border:2px solid #444;
  display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0; transition:all 0.2s;
}
.exercise-checkbox.checked { background:var(--text-green); border-color:var(--text-green); }
.exercise-checkbox.checked::after { content:''; width:8px; height:8px; background:#000; border-radius:50%; }
.exercise-info { flex:1; }
.exercise-name { font-size:14px; font-weight:500; }
.exercise-sets { font-size:11px; color:var(--text-secondary); margin-top:2px; }
.exercise-checkbox.checked ~ .exercise-info .exercise-name { color:#666; text-decoration:line-through; }
.start-workout-btn {
  margin:12px 16px 16px; background:linear-gradient(135deg,#00ff6a,#00cc55); color:#000;
  border:none; border-radius:12px; padding:12px; font-size:15px; font-weight:700;
  cursor:pointer; width:calc(100% - 32px); letter-spacing:1px; transition:all 0.2s;
}
.start-workout-btn.rest-day { background:linear-gradient(135deg,#ff6a00,#cc5500); }
/* Quick Action Buttons */
.quick-actions { display:flex; gap:8px; padding:0 16px; margin-bottom:16px; }
.quick-action {
  flex:1; background:var(--bg-card); border:1px solid #222; border-radius:12px;
  padding:14px 8px; text-align:center; cursor:pointer; transition:all 0.2s;
}
.quick-action:active { transform:scale(0.96); background:var(--bg-card-hover); }
.quick-action-icon { font-size:22px; margin-bottom:4px; }
.quick-action-label { font-size:11px; color:var(--text-secondary); }
/* ===== Plan Page ===== */
.plan-header { padding:16px; display:flex; justify-content:space-between; align-items:center; }
.plan-title { font-size:17px; font-weight:700; }
.plan-equip-badge {
  background:rgba(0,255,106,0.1); border:1px solid rgba(0,255,106,0.3);
  color:var(--text-green); padding:4px 12px; border-radius:20px; font-size:12px;
}
.plan-day-card {
  margin:0 16px 12px; background:var(--bg-card); border-radius:14px;
  border:1px solid #222; overflow:hidden;
}
.plan-day-header {
  padding:12px 16px; display:flex; justify-content:space-between; align-items:center;
  cursor:pointer; transition:background 0.2s;
}
.plan-day-header:active { background:var(--bg-card-hover); }
.plan-day-name { font-size:14px; font-weight:600; }
.plan-day-rest { color:var(--text-orange); }
.plan-day-num { font-size:12px; color:var(--text-secondary); }
.plan-day-exercises { padding:0 16px 12px; display:none; }
.plan-day-exercises.expanded { display:block; }
.plan-exercise-row {
  display:flex; align-items:center; padding:8px 0; gap:10px;
  border-bottom:1px solid #1a1a1a;
}
.plan-exercise-row:last-child { border-bottom:none; }
.plan-exercise-idx { font-size:12px; color:var(--text-green); width:20px; }
.plan-exercise-name { flex:1; font-size:13px; }
.plan-exercise-sets { font-size:11px; color:var(--text-secondary); }
.plan-switch-btn {
  margin:16px; background:none; border:2px solid var(--text-green); color:var(--text-green);
  border-radius:12px; padding:12px; font-size:14px; font-weight:600; cursor:pointer; width:calc(100% - 32px);
  transition:all 0.2s;
}
.plan-switch-btn:active { background:rgba(0,255,106,0.1); }
/* Equipment Select Modal */
.modal-overlay {
  position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.85);
  z-index:1000; display:none; align-items:center; justify-content:center; padding:20px;
}
.modal-overlay.active { display:flex; }
.modal-content {
  background:var(--bg-secondary); border-radius:20px; padding:24px; width:100%;
  max-width:400px; max-height:80vh; overflow-y:auto; border:1px solid #333;
}
.modal-title { font-size:17px; font-weight:700; margin-bottom:16px; text-align:center; }
.modal-equip-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:20px; }
.modal-btn {
  background:linear-gradient(135deg,#00ff6a,#00cc55); color:#000; border:none;
  border-radius:12px; padding:12px; font-size:15px; font-weight:700; cursor:pointer; width:100%;
}
/* ===== Workout Active Page ===== */
.workout-active-page { display:none; flex-direction:column; height:100%; background:var(--bg-primary); position:absolute; top:0; left:0; right:0; bottom:0; z-index:500; }
.workout-active-page.active { display:flex; }
.workout-top-bar {
  display:flex; align-items:center; justify-content:space-between;
  padding:12px 16px; border-bottom:1px solid #222;
}
.workout-back-btn { background:none; border:none; color:var(--text-green); font-size:14px; cursor:pointer; padding:4px 8px; }
.workout-progress-text { font-size:13px; color:var(--text-secondary); }
.workout-progress-bar { height:3px; background:#222; }
.workout-progress-fill { height:100%; background:var(--text-green); transition:width 0.3s; box-shadow:var(--glow-green); }
.workout-exercise-active { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:30px 20px; }
.workout-exercise-name { font-size:24px; font-weight:700; margin-bottom:8px; text-align:center; }
.workout-exercise-sets-info { font-size:14px; color:var(--text-secondary); margin-bottom:30px; }
.workout-timer { font-size:48px; font-weight:700; color:var(--text-green); margin-bottom:30px; font-variant-numeric:tabular-nums; text-shadow:0 0 20px rgba(0,255,106,0.3); }
.workout-set-btns { display:flex; gap:12px; margin-bottom:20px; }
.workout-set-btn {
  width:60px; height:60px; border-radius:50%; border:2px solid #444; background:var(--bg-card);
  color:var(--text-primary); font-size:14px; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; justify-content:center;
}
.workout-set-btn.done { border-color:var(--text-green); color:var(--text-green); }
.workout-next-btn {
  background:linear-gradient(135deg,#00ff6a,#00cc55); color:#000; border:none;
  border-radius:25px; padding:14px 50px; font-size:16px; font-weight:700; cursor:pointer; transition:all 0.2s;
}
.workout-complete-overlay {
  display:none; position:absolute; top:0; left:0; right:0; bottom:0;
  background:rgba(0,0,0,0.95); z-index:600; flex-direction:column;
  align-items:center; justify-content:center; text-align:center; padding:30px;
}
.workout-complete-overlay.active { display:flex; }
.workout-complete-emoji { font-size:64px; margin-bottom:16px; }
.workout-complete-title { font-size:24px; font-weight:700; color:var(--text-green); margin-bottom:8px; }
/* ===== Diet Page ===== */
.diet-date-nav { display:flex; align-items:center; justify-content:space-between; padding:12px 16px; }
.diet-date-btn { background:none; border:none; color:var(--text-green); font-size:18px; cursor:pointer; padding:4px 8px; }
.diet-date-text { font-size:14px; }
.diet-summary-card {
  margin:0 16px 16px; background:var(--bg-card); border-radius:16px; padding:16px; border:1px solid #222;
}
.diet-cal-bar { height:8px; background:#222; border-radius:4px; margin:10px 0; overflow:hidden; }
.diet-cal-fill { height:100%; border-radius:4px; transition:width 0.3s; }
.diet-cal-fill.surplus { background:linear-gradient(90deg,#ff4444,#ff6666); }
.diet-cal-fill.deficit { background:linear-gradient(90deg,#00ff6a,#00cc55); }
.diet-cal-labels { display:flex; justify-content:space-between; font-size:12px; color:var(--text-secondary); }
.diet-meal-section { margin:0 16px 12px; }
.diet-meal-header { display:flex; justify-content:space-between; align-items:center; padding:10px 0; cursor:pointer; }
.diet-meal-name { font-size:14px; font-weight:600; }
.diet-meal-cal { font-size:12px; color:var(--text-secondary); }
.diet-meal-add { background:none; border:1px dashed #444; border-radius:8px; padding:8px; text-align:center; color:var(--text-green); font-size:12px; cursor:pointer; margin-top:6px; }
.quick-foods { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }
.quick-food-btn {
  background:var(--bg-card); border:1px solid #333; border-radius:8px; padding:6px 10px;
  font-size:11px; color:var(--text-primary); cursor:pointer; transition:all 0.2s;
}
.quick-food-btn:active { border-color:var(--text-green); }
/* ===== Data Page ===== */
.data-section { margin:0 16px 20px; }
.data-section-title { font-size:14px; font-weight:600; margin-bottom:10px; color:var(--text-green); }
.weight-input-row { display:flex; gap:8px; margin-bottom:12px; }
.weight-input {
  flex:1; background:var(--bg-card); border:1px solid #333; border-radius:10px;
  padding:10px 12px; color:var(--text-primary); font-size:14px; outline:none;
}
.weight-input:focus { border-color:var(--text-green); }
.weight-input-btn {
  background:var(--text-green); color:#000; border:none; border-radius:10px;
  padding:10px 16px; font-weight:700; cursor:pointer; font-size:13px;
}
.chart-container { background:var(--bg-card); border-radius:14px; padding:12px; border:1px solid #222; margin-bottom:12px; }
.chart-canvas { width:100%; height:200px; }
/* ===== Stats Page ===== */
.stats-card { margin:0 16px 16px; background:var(--bg-card); border-radius:14px; padding:16px; border:1px solid #222; }
.stats-big-number { font-size:36px; font-weight:700; color:var(--text-green); }
.stats-label { font-size:12px; color:var(--text-secondary); }
.stats-row { display:flex; gap:8px; margin-top:12px; }
.stats-mini-card { flex:1; background:var(--bg-secondary); border-radius:10px; padding:10px; text-align:center; }
.stats-mini-value { font-size:16px; font-weight:700; }
.stats-mini-label { font-size:10px; color:var(--text-secondary); }
/* ===== Settings Page ===== */
.settings-group { margin:0 16px 20px; }
.settings-group-title { font-size:12px; color:var(--text-secondary); margin-bottom:8px; text-transform:uppercase; letter-spacing:1px; }
.settings-item {
  display:flex; align-items:center; justify-content:space-between;
  padding:12px 0; border-bottom:1px solid #1a1a1a;
}
.settings-item:last-child { border-bottom:none; }
.settings-item-label { font-size:14px; }
.settings-item-value { font-size:13px; color:var(--text-secondary); }
.settings-item-input {
  background:var(--bg-secondary); border:1px solid #333; border-radius:8px;
  padding:6px 10px; color:var(--text-primary); font-size:13px; width:80px; text-align:center; outline:none;
}
.settings-item-input:focus { border-color:var(--text-green); }
.settings-btn {
  display:block; width:100%; padding:12px; border-radius:12px; font-size:14px;
  cursor:pointer; text-align:center; margin-top:6px; transition:all 0.2s;
}
.btn-export { background:var(--bg-card); border:1px solid #333; color:var(--text-primary); }
.btn-reset { background:none; border:1px solid #ff4444; color:#ff4444; }
/* ===== Bottom Nav ===== */
.bottom-nav {
  display:flex; height:var(--nav-height); background:var(--bg-secondary);
  border-top:1px solid #222; padding-bottom:var(--safe-bottom);
}
.nav-item {
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  cursor:pointer; color:var(--text-secondary); transition:all 0.2s; position:relative;
  -webkit-tap-highlight-color:transparent;
}
.nav-item.active { color:var(--text-green); }
.nav-item.active::before {
  content:''; position:absolute; top:0; left:50%; transform:translateX(-50%);
  width:30px; height:3px; background:var(--text-green); border-radius:0 0 3px 3px;
  box-shadow:var(--glow-green);
}
.nav-icon { font-size:20px; margin-bottom:2px; }
.nav-icon svg { width:20px; height:20px; }
.nav-label { font-size:10px; }
/* ===== Toast ===== */
.toast {
  position:fixed; bottom:80px; left:50%; transform:translateX(-50%);
  background:var(--bg-card); color:var(--text-green); padding:10px 24px;
  border-radius:25px; font-size:13px; font-weight:600; z-index:9999;
  border:1px solid var(--text-green); opacity:0; transition:opacity 0.3s; pointer-events:none;
}
.toast.show { opacity:1; }
/* ===== Rest Day Animation ===== */
@keyframes restGlow {
  0%,100% { box-shadow:0 0 5px rgba(255,106,0,0.2); }
  50% { box-shadow:0 0 20px rgba(255,106,0,0.4); }
}
.rest-card { animation:restGlow 2s infinite; }
/* ===== Scrollbar ===== */
::-webkit-scrollbar { width:0; }
/* ===== Walk Checkin ===== */
.walk-checkin {
  margin:0 16px 16px; background:var(--bg-card); border-radius:12px; padding:14px 16px;
  display:flex; align-items:center; justify-content:space-between; border:1px solid #222;
}
.walk-checkin.done { border-color:rgba(0,255,106,0.3); }
.walk-icon { font-size:20px; margin-right:10px; }
.walk-info { flex:1; }
.walk-name { font-size:14px; font-weight:500; }
.walk-desc { font-size:11px; color:var(--text-secondary); }
.walk-btn {
  background:var(--text-green); color:#000; border:none; border-radius:20px;
  padding:6px 16px; font-size:12px; font-weight:700; cursor:pointer;
}
.walk-btn.done { background:rgba(0,255,106,0.2); color:var(--text-green); }
</style>
</head>
<body>
<div class="app-container" id="app">

  <!-- ===== Header ===== -->
  <div class="app-header">
    <div>
      <div class="app-title" id="headerTitle">⚡ 怪兽训练</div>
      <div class="app-subtitle" id="headerSubtitle">今天也要全力以赴</div>
    </div>
    <div class="header-right">
      <button class="header-btn" onclick="exportData()" title="导出数据">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </button>
    </div>
  </div>

  <!-- ===== Onboarding Page ===== -->
  <div class="page active" id="page-onboarding">
    <div class="onboarding-page">
      <h1>⚡ 怪兽训练计划</h1>
      <p>打造你的专属训练方案<br>选择器材，设定目标，开始变身</p>

      <div class="onboarding-step">
        <h3>01 选择训练器材</h3>
        <div class="equip-grid" id="onboardingEquipGrid"></div>
      </div>

      <div class="onboarding-step">
        <h3>02 设定训练目标</h3>
        <div class="goal-options" id="onboardingGoalOptions"></div>
      </div>

      <div class="onboarding-step">
        <h3>03 每周训练频率</h3>
        <div class="freq-options" id="onboardingFreqOptions"></div>
      </div>

      <div class="onboarding-step" id="onboardingBodyStep" style="display:none;">
        <h3>04 身体数据（选填）</h3>
        <div style="display:flex;gap:8px;">
          <input type="number" id="onboardingHeight" placeholder="身高cm" style="flex:1;background:#1a1a1a;border:1px solid #333;border-radius:10px;padding:10px;color:#e0e0e0;font-size:14px;">
          <input type="number" id="onboardingWeight" placeholder="体重kg" style="flex:1;background:#1a1a1a;border:1px solid #333;border-radius:10px;padding:10px;color:#e0e0e0;font-size:14px;">
        </div>
      </div>

      <button class="btn-primary" onclick="completeOnboarding()">开始训练 →</button>
    </div>
  </div>

  <!-- ===== Today Page ===== -->
  <div class="page" id="page-today">
    <div class="today-hero">
      <div class="today-date" id="todayDate"></div>
      <div class="today-greeting" id="todayGreeting"></div>
      <div class="today-streak" id="todayStreak" style="display:none;"></div>
    </div>

    <div class="quick-stats" id="todayQuickStats"></div>

    <div class="walk-checkin" id="walkCheckin" onclick="toggleWalk()">
      <span class="walk-icon">🚶</span>
      <div class="walk-info">
        <div class="walk-name">今日步行 5km</div>
        <div class="walk-desc">约消耗 300 kcal</div>
      </div>
      <button class="walk-btn" id="walkBtn">打卡</button>
    </div>

    <div class="today-workout-card" id="todayWorkoutCard">
      <div class="today-workout-header">
        <div class="today-workout-title" id="todayWorkoutTitle">今日训练</div>
        <div class="today-workout-tag" id="todayWorkoutTag">训练日</div>
      </div>
      <div class="today-exercise-list" id="todayExerciseList"></div>
      <button class="start-workout-btn" id="startWorkoutBtn" onclick="startWorkout()">开始训练 ⚡</button>
    </div>

    <div class="quick-actions">
      <div class="quick-action" onclick="switchPage('diet')">
        <div class="quick-action-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00ff6a" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
        </div>
        <div class="quick-action-label">记录饮食</div>
      </div>
      <div class="quick-action" onclick="switchPage('data')">
        <div class="quick-action-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00ff6a" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="quick-action-label">记录体重</div>
      </div>
      <div class="quick-action" onclick="switchPage('stats')">
        <div class="quick-action-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00ff6a" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <div class="quick-action-label">查看统计</div>
      </div>
    </div>
  </div>

  <!-- ===== Plan Page ===== -->
  <div class="page" id="page-plan">
    <div class="plan-header">
      <div class="plan-title">📋 训练计划</div>
      <div class="plan-equip-badge" id="planEquipBadge">拉力绳</div>
    </div>
    <div id="planDayList"></div>
    <button class="plan-switch-btn" onclick="showEquipModal()">🔄 切换训练器材/方案</button>
  </div>

  <!-- ===== Workout Active Overlay ===== -->
  <div class="workout-active-page" id="workoutActive">
    <div class="workout-top-bar">
      <button class="workout-back-btn" onclick="exitWorkout()">← 退出</button>
      <div class="workout-progress-text" id="workoutProgressText">1 / 5</div>
    </div>
    <div class="workout-progress-bar"><div class="workout-progress-fill" id="workoutProgressFill"></div></div>
    <div class="workout-exercise-active">
      <div class="workout-exercise-name" id="activeExName"></div>
      <div class="workout-exercise-sets-info" id="activeExSets"></div>
      <div class="workout-timer" id="activeTimer">00:00</div>
      <div class="workout-set-btns" id="activeSetBtns"></div>
      <button class="workout-next-btn" id="activeNextBtn" onclick="nextExercise()">完成这组 ✓</button>
    </div>
    <div class="workout-complete-overlay" id="workoutComplete">
      <div class="workout-complete-emoji">🎉</div>
      <div class="workout-complete-title">训练完成！</div>
      <div style="color:#888;margin-bottom:30px;" id="completeStats"></div>
      <button class="workout-next-btn" onclick="exitWorkout()">返回首页</button>
    </div>
  </div>

  <!-- ===== Diet Page ===== -->
  <div class="page" id="page-diet">
    <div class="diet-date-nav">
      <button class="diet-date-btn" onclick="changeDietDate(-1)">‹</button>
      <div class="diet-date-text" id="dietDateText"></div>
      <button class="diet-date-btn" onclick="changeDietDate(1)">›</button>
    </div>
    <div class="diet-summary-card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <div style="font-size:14px;font-weight:600;">今日热量</div>
        <div style="font-size:12px;color:var(--text-secondary);" id="dietCalText">0 / 0 kcal</div>
      </div>
      <div class="diet-cal-bar"><div class="diet-cal-fill" id="dietCalFill"></div></div>
      <div class="diet-cal-labels">
        <span id="dietIntakeText">摄入: 0 kcal</span>
        <span id="dietBurnText">消耗: 0 kcal</span>
      </div>
    </div>
    <div id="dietMealList"></div>
    <div style="padding:0 16px;margin-top:12px;">
      <div style="fontize:12px;color:var(--text-secondary);margin-bottom:8px;">快捷添加（点击增加）</div>
      <div class="quick-foods" id="quickFoodList"></div>
    </div>
  </div>

  <!-- ===== Data Page ===== -->
  <div class="page" id="page-data">
    <div style="padding:16px 16px 8px;"><div style="font-size:17px;font-weight:700;">📊 身体数据</div></div>
    <div class="data-section">
      <div class="data-section-title">⚖️ 体重记录</div>
      <div class="weight-input-row">
        <input type="number" step="0.1" class="weight-input" id="weightInput" placeholder="今日体重 kg">
        <button class="weight-input-btn" onclick="addWeight()">记录</button>
      </div>
      <div class="chart-container"><canvas class="chart-canvas" id="weightChart"></canvas></div>
    </div>
    <div class="data-section">
      <div class="data-section-title">📏 围度记录（选填）</div>
      <div style="display:grid;grid-template-columns:repeat(2,gap:8px;margin-bottom:12px;">
        <input type="number" step="0.1" class="weight-input" id="chestInput" placeholder="胸围 cm">
        <input type="number" step="0.1" class="weight-input" id="armInput" placeholder="臂围 cm">
        <input type="number" step="0.1" class="weight-input" id="waistInput" placeholder="腰围 cm">
        <input type="number" step="0.1" class="weight-input" id="thighInput" placeholder="大腿围 cm">
      </div>
      <button class="weight-input-btn" onclick="addMeasurement()" style="width:100%;margin-bottom:12px;">记录围度</button>
      <div class="chart-container"><canvas class="chart-canvas" id="measurementChart"></canvas></div>
    </div>
    <div class="data-section">
      <div class="data-section-title">💧 饮水记录</div>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
        <div style="flex:1;background:var(--bg-card);border-radius:10px;padding:12px;border:1px solid #222;">
          <div style="font-size:20px;font-weight:700;color:var(--text-green);" id="waterAmount">0</div>
          <div style="font-size:11px;color:var(--text-secondary);">/ 2500 ml</div>
        </div>
        <button class="weight-input-btn" onclick="addWater(250)">+250ml</button>
        <button class="weight-input-btn" onclick="addWater(500)">+500ml</button>
      </div>
    </div>
  </div>

  <!-- ===== Stats Page ===== -->
  <div class="page" id="page-stats">
    <div style="padding:16px 16px 8px;"><div style="font-size:17px;font-weight:700;">📈 综合统计</div></div>
    <div class="stats-card">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <div class="stats-big-number" id="statsStreak">0</div>
          <div class="stats-label">连续打卡天数</div>
        </div>
        <div style="text-align:right;">
          <div class="stats-big-number" id="statsTotal" style="font-size:24px;">0</div>
          <div class="stats-label">总训练次数</div>
        </div>
      </div>
      <div class="stats-row">
        <div class="stats-mini-card">
          <div class="stats-mini-value" id="statsWeekRate" style="color:var(--text-green);">0%</div>
          <div class="stats-mini-label">本周完成率</div>
        </div>
        <div class="stats-mini-card">
          <div class="stats-mini-value" id="statsMonthRate" style="color:var(--text-orange);">0%</div>
          <div class="stats-mini-label">本月完成率</div>
        </div>
        <div class="stats-mini-card">
          <div class="stats-mini-value" id="statsWeightChange">--</div>
          <div class="stats-mini-label">体重变化</div>
        </div>
      </div>
    </div>
    <div class="stats-card">
      <div style="font-size:14px;font-weight:600;margin-bottom:12px;">📅 本周训练打卡</div>
      <div id="statsWeekGrid" style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;"></div>
    </div>
    <div class="stats-card">
      <div style="font-size:14px;font-weight:600;margin-bottom:12px;">📊 热量趋势（近7天）</div>
      <div class="chart-container"><canvas class="chart-canvas" id="calChart" style="height:180px;"></canvas></div>
    </div>
  </div>

  <!-- ===== Settings Page ===== -->
  <div class="page" id="page-settings">
    <div style="padding:16px 16px 8px;"><div style="font-size:17px;font-weight:700;">⚙️ 设置</div></div>
    <div class="settings-group">
      <div class="settings-group-title">个人信息</div>
      <div class="settings-item">
        <div class="settings-item-label">出生年份</div>
        <input type="number" class="settings-item-input" id="settingBirthYear" placeholder="1987">
      </div>
      <div class="settings-item">
        <div class="settings-item-label">身高 (cm)</div>
        <input type="number" class="settings-item-input" id="settingHeight" placeholder="170">
      </div>
      <div class="settings-item">
        <div class="settings-item-label">当前体重 (kg)</div>
        <input type="number" step="0.1" class="settings-item-input" id="settingWeight" placeholder="65">
      </div>
      <div class="settings-item">
        <div class="settings-item-label">目标体重 (kg)</div>
        <input type="number" step="0.1" class="settings-item-input" id="settingGoalWeight" placeholder="75">
      </div>
      <div class="settings-item">
        <div class="settings-item-label">性别</div>
        <div style="display:flex;gap:8px;">
          <button class="settings-btn" style="flex:1;border:1px solid #333;color:var(--text-secondary);" onclick="setGender('male')" id="genderMale">♂ 男</button>
          <button class="settings-btn" style="flex:1;border:1px solid #333;color:var(--text-secondary);" onclick="setGender('female')" id="genderFemale">♀ 女</button>
        </div>
      </div>
    </div>
    <div class="settings-group">
      <div class="settings-group-title">训练设置</div>
      <div class="settings-item">
        <div class="settings-item-label">当前器材</div>
        <div class="settings-item-value" id="settingEquip">拉力绳</div>
      </div>
      <div class="settings-item">
        <div class="settings-item-label">训练目标</div>
        <div class="settings-item-value" id="settingGoal">增肌</div>
      </div>
    </div>
    <div class="settings-group">
      <div class="settings-group-title">数据管理</div>
      <button class="settings-btn btn-export" onclick="exportData()">📤 导出数据备份</button>
      <button class="settings-btn btn-reset" onclick="resetData()">🗑️ 重置所有数据</button>
    </div>
    <div style="text-align:center;padding:20px;color:var(--text-secondary);font-size:11px;">
      ⚡ 怪兽训练计划 v3.0<br>
      数据保存在本地浏览器
    </div>
  </div>

  <!-- ===== Equip Switch Modal ===== -->
  <div class="modal-overlay" id="equipModal">
    <div class="modal-content">
      <div class="modal-title">切换训练器材</div>
      <div class="modal-equip-grid" id="modalEquipGrid"></div>
      <div style="margin-bottom:16px;">
        <div style="font-size:13px;color:var(--text-secondary);margin-bottom:8px;">训练目标</div>
        <div style="display:flex;gap:8px;">
          <button class="modal-goal-btn" onclick="selectModalGoal('muscle')" id="modalGoalMuscle" style="flex:1;padding:8px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#e0e0e0;font-size:12px;cursor:pointer;">💪 增肌</button>
          <button class="modal-goal-btn" onclick="selectModalGoal('strength')" id="modalGoalStrength" style="flex:1;padding:8px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#e0e0e0;font-size:12px;cursor:pointer;">🔥 力量</button>
          <button class="modal-goal-btn" onclick="selectModalGoal('weight_loss')" id="modalGoalWeightLoss" style="flex:1;padding:8px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#e0e0e0;font-size:12px;cursor:pointer;">🏃 减脂</button>
        </div>
      </div>
      <button class="modal-btn" onclick="applyEquipSwitch()">生成新方案 →</button>
      <button style="background:none;border:none;color:#888;margin-top:12px;font-size:13px;cursor:pointer;width:100%;" onclick="hideEquipModal()">取消</button>
    </div>
  </div>

  <!-- ===== Bottom Nav ===== -->
  <div class="bottom-nav" id="bottomNav">
    <div class="nav-item active" onclick="switchPage('today')" data-page="today">
      <div class="nav-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <div class="nav-label">今日</div>
    </div>
    <div class="nav-item" onclick="switchPage('plan')" data-page="plan">
      <div class="nav-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </div>
      <div class="nav-label">计划</div>
    </div>
    <div class="nav-item" onclick="switchPage('diet')" data-page="diet">
      <div class="nav-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
      </div>
      <div class="nav-label">饮食</div>
    </div>
    <div class="nav-item" onclick="switchPage('data')" data-page="data">
      <div class="nav-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div class="nav-label">数据</div>
    </div>
    <div class="nav-item" onclick="switchPage('stats')" data-page="stats">
      <div class="nav-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      </div>
      <div class="nav-label">统计</div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>// ===================================================================
// 怪兽训练计划 v3 - 可扩展训练系统
// ===================================================================

// ===== Equipment & Goal Config =====
var EQUIPMENT = {
  band:      { id:'band',      name:'拉力绳',   icon:'🎯', desc:'居家拉力绳训练' },
  dumbbell:  { id:'dumbbell',  name:'哑铃',     icon:'🏋',  desc:'哑铃力量训练' },
  barbell:   { id:'barbell',   name:'杠铃',     icon:'🏋',  desc:'杠铃复合训练' },
  bodyweight:{ id:'bodyweight',name:'徒手',     icon:'💪', desc:'自重训练' },
  kettlebell:{ id:'kettlebell',name:'壶铃',     icon:'🔔', desc:'壶铃爆发力训练' },
  mixed:     { id:'mixed',     name:'综合器材', icon:'⚡', desc:'多器材组合训练' },
};

var GOALS = {
  muscle:      { id:'muscle',      name:'增肌',   icon:'💪', desc:'增加肌肉量，雕塑体型' },
  strength:    { id:'strength',    name:'力量',   icon:'🔥', desc:'提升最大力量' },
  weight_loss: { id:'weight_loss', name:'减脂',   icon:'🏃', desc:'燃烧脂肪，塑形减脂' },
  endurance:   { id:'endurance',   name:'耐力',   icon:'❤️', desc:'提升心肺耐力' },
};

// ===== Exercise Database (Extensible) =====
var EXERCISE_DB = [
  // 拉力绳
  { name:'拉力绳胸推',     equip:['band'],     muscle:'chest',  difficulty:1, sets:4, reps:'12-15', rest:60 },
  { name:'拉力绳飞鸟',     equip:['band'],     muscle:'chest',  difficulty:1, sets:3, reps:'15-20', rest:45 },
  { name:'拉力绳高位下拉', equip:['band'],     muscle:'back',   difficulty:2, sets:4, reps:'12-15', rest:60 },
  { name:'拉力绳坐姿划船', equip:['band'],     muscle:'back',   difficulty:1, sets:4, reps:'12-15', rest:60 },
  { name:'拉力绳直臂下压', equip:['band'],     muscle:'back',   difficulty:1, sets:3, reps:'15-20', rest:45 },
  { name:'拉力绳深蹲',     equip:['band'],     muscle:'legs',   difficulty:2, sets:4, reps:'15-20', rest:60 },
  { name:'拉力绳箭步蹲',   equip:['band'],     muscle:'legs',   difficulty:2, sets:3, reps:'12/腿', rest:60 },
  { name:'拉力绳腿弯举',   equip:['band'],     muscle:'legs',   difficulty:2, sets:3, reps:'15-20', rest:60 },
  { name:'拉力绳肩推',     equip:['band'],     muscle:'shoulder',difficulty:1, sets:4, reps:'12-15', rest:60 },
  { name:'拉力绳侧平举',   equip:['band'],     muscle:'shoulder',difficulty:1, sets:3, reps:'15-20', rest:45 },
  { name:'拉力绳面拉',     equip:['band'],     muscle:'shoulder',difficulty:2, sets:3, reps:'15-20', rest:60 },
  { name:'拉力绳二头弯举', equip:['band'],     muscle:'arm',    difficulty:1, sets:3, reps:'12-15', rest:45 },
  { name:'拉力绳三头下压', equip:['band'],     muscle:'arm',    difficulty:1, sets:3, reps:'12-15', rest:45 },
  { name:'拉力绳臀桥',     equip:['band'],     muscle:'legs',   difficulty:1, sets:4, reps:'15-20', rest:60 },
  // 哑铃
  { name:'哑铃平卧推',     equip:['dumbbell'], muscle:'chest',  difficulty:2, sets:4, reps:'10-12', rest:60 },
  { name:'哑铃上斜推',     equip:['dumbbell'], muscle:'chest',  difficulty:2, sets:4, reps:'10-12', rest:60 },
  { name:'哑铃飞鸟',       equip:['dumbbell'], muscle:'chest',  difficulty:1, sets:3, reps:'12-15', rest:45 },
  { name:'哑铃单臂划船',   equip:['dumbbell'], muscle:'back',   difficulty:2, sets:4, reps:'10-12/臂', rest:60 },
  { name:'哑铃硬拉',       equip:['dumbbell'], muscle:'back',   difficulty:2, sets:4, reps:'10-12', rest:60 },
  { name:'哑铃深蹲',       equip:['dumbbell'], muscle:'legs',   difficulty:2, sets:4, reps:'10-15', rest:60 },
  { name:'哑铃箭步蹲',     equip:['dumbbell'], muscle:'legs',   difficulty:2, sets:3, reps:'10/腿', rest:60 },
  { name:'哑铃肩推',       equip:['dumbbell'], muscle:'shoulder',difficulty:2, sets:4, reps:'10-12', rest:60 },
  { name:'哑铃侧平举',     equip:['dumbbell'], muscle:'shoulder',difficulty:1, sets:3, reps:'12-15', rest:45 },
  { name:'哑铃弯举',       equip:['dumbbell'], muscle:'arm',    difficulty:1, sets:3, reps:'10-12', rest:45 },
  { name:'哑铃三头屈伸',   equip:['dumbbell'], muscle:'arm',    difficulty:2, sets:3, reps:'10-12', rest:45 },
  // 杠铃
  { name:'杠铃平卧推',     equip:['barbell'],  muscle:'chest',  difficulty:3, sets:5, reps:'5-8', rest:90 },
  { name:'杠铃深蹲',       equip:['barbell'],  muscle:'legs',   difficulty:3, sets:5, reps:'5-8', rest:120 },
  { name:'杠铃硬拉',       equip:['barbell'],  muscle:'back',   difficulty:3, sets:5, reps:'5-8', rest:120 },
  { name:'杠铃划船',       equip:['barbell'],  muscle:'back',   difficulty:3, sets:4, reps:'6-10', rest:90 },
  { name:'杠铃肩推',       equip:['barbell'],  muscle:'shoulder',difficulty:3, sets:4, reps:'6-10', rest:90 },
  // 徒手
  { name:'俯卧撑',         equip:['bodyweight'],muscle:'chest',  difficulty:1, sets:4, reps:'10-20', rest:45 },
  { name:'钻石俯卧撑',     equip:['bodyweight'],muscle:'chest',  difficulty:2, sets:3, reps:'8-12', rest:45 },
  { name:'引体向上',       equip:['bodyweight'],muscle:'back',   difficulty:3, sets:4, reps:'5-10', rest:60 },
  { name:'徒手深蹲',       equip:['bodyweight'],muscle:'legs',   difficulty:1, sets:4, reps:'20-30', rest:45 },
  { name:'徒手箭步蹲',     equip:['bodyweight'],muscle:'legs',   difficulty:2, sets:3, reps:'12/腿', rest:60 },
  { name:'平板支撑',       equip:['bodyweight'],muscle:'core',   difficulty:1, sets:3, reps:'30-60秒', rest:45 },
  { name:'卷腹',           equip:['bodyweight'],muscle:'core',   difficulty:1, sets:4, reps:'15-20', rest:30 },
  { name:'登山跑',         equip:['bodyweight'],muscle:'core',   difficulty:2, sets:3, reps:'30秒', rest:30 },
  // 壶铃
  { name:'壶铃摇摆',       equip:['kettlebell'],muscle:'legs',   difficulty:2, sets:4, reps:'15-20', rest:60 },
  { name:'壶铃高脚杯深蹲', equip:['kettlebell'],muscle:'legs',   difficulty:2, sets:4, reps:'10-12', rest:60 },
  { name:'壶铃单臂划船',   equip:['kettlebell'],muscle:'back',   difficulty:2, sets:3, reps:'10-12/臂', rest:60 },
  { name:'壶铃肩推',       equip:['kettlebell'],muscle:'shoulder',difficulty:2, sets:3, reps:'8-12', rest:60 },
  // 核心
  { name:'平板支撑',       equip:['bodyweight'],muscle:'core',  difficulty:1, sets:3, reps:'30-60秒', rest:45 },
  { name:'俄罗斯转体',     equip:['bodyweight'],muscle:'core',  difficulty:2, sets:3, reps:'20', rest:45 },
  { name:'死虫式',         equip:['bodyweight'],muscle:'core',  difficulty:1, sets:3, reps:'12/侧', rest:45 },
  { name:'仰卧举腿',       equip:['bodyweight'],muscle:'core',  difficulty:1, sets:3, reps:'15', rest:45 },
];

// ===== Plan Generator =====
function generatePlan(equipId, goalId, freqPerWeek) {
  if (!EQUIPMENT[equipId]) return [];
  var availExercises = EXERCISE_DB.filter(function(e) { return e.equip.indexOf(equipId) >= 0; });
  if (availExercises.length === 0) return [];

  var goalConfig = {
    muscle:      { repsRange:'8-12',  setCount:4, restTime:60, preferMuscle:['chest','back','legs','shoulder'] },
    strength:    { repsRange:'5-8',  setCount:5, restTime:90, preferMuscle:['chest','back','legs'] },
    weight_loss: { repsRange:'15-20', setCount:3, restTime:30, preferMuscle:['legs','chest','core','full'] },
    endurance:   { repsRange:'15-20', setCount:3, restTime:30, preferMuscle:['legs','core','chest'] },
  };
  var config = goalConfig[goalId] || goalConfig['muscle'];

  var splitPlan;
  if (freqPerWeek <= 3) {
    splitPlan = [
      { name:'全身训练A', muscles:['chest','back','legs','shoulder','core'] },
      { name:'全身训练B', muscles:['chest','back','legs','arm','core'] },
      { name:'全身训练C', muscles:['chest','back','legs','shoulder','arm','core'] },
    ];
  } else if (freqPerWeek <= 4) {
    splitPlan = [
      { name:'上肢推', muscles:['chest','shoulder','arm'] },
      { name:'上肢拉', muscles:['back','arm','shoulder'] },
      { name:'下肢A',  muscles:['legs','core'] },
      { name:'下肢B',  muscles:['legs','core'] },
    ];
  } else {
    splitPlan = [
      { name:'推日(Push)',  muscles:['chest','shoulder','arm'] },
      { name:'拉日(Pull)',  muscles:['back','arm'] },
      { name:'腿日(Legs)',  muscles:['legs','core'] },
      { name:'推日2',       muscles:['chest','shoulder'] },
      { name:'拉日2',       muscles:['back','shoulder','arm'] },
    ];
  }

  var plan = [];
  var usedExercises = {};

  for (var i = 0; i < Math.min(splitPlan.length, freqPerWeek); i++) {
    var day = splitPlan[i];
    var dayExercises = [];

    for (var m = 0; m < day.muscles.length; m++) {
      var muscle = day.muscles[m];
      var candidates = availExercises.filter(function(e) {
        return (e.muscle === muscle || e.muscle === 'full') && !usedExercises[e.name];
      });
      if (candidates.length === 0) {
        candidates = availExercises.filter(function(e) {
          return e.muscle === muscle && !usedExercises[e.name];
        });
      }
      if (candidates.length === 0) continue;
      candidates.sort(function(a, b) { return a.difficulty - b.difficulty; });
      var selected = candidates[0];
      usedExercises[selected.name] = true;
      dayExercises.push({
        name: selected.name,
        sets: config.setCount,
        reps: selected.reps || config.repsRange,
        rest: selected.rest || config.restTime,
      });
    }

    while (dayExercises.length < 5 && availExercises.length > dayExercises.length) {
      var unused = availExercises.filter(function(e) { return !usedExercises[e.name]; });
      if (unused.length === 0) break;
      var ex = unused[0];
      usedExercises[ex.name] = true;
      dayExercises.push({
        name: ex.name,
        sets: config.setCount,
        reps: ex.reps || config.repsRange,
        rest: ex.rest || config.restTime,
      });
    }

    plan.push({ name: day.name, exercises: dayExercises, isRest: false });
  }

  while (plan.length < freqPerWeek) {
    plan.push({
      name: '休息/拉伸',
      exercises: [
        { name:'全身拉伸', sets:1, reps:'10分钟', rest:0 },
        { name:'泡沫轴放松', sets:1, reps:'5分钟', rest:0 },
      ],
      isRest: true,
    });
  }
  return plan;
}

// ===== State =====
var state = {
  onboardingDone: false,
  equipment: 'band',
  goal: 'muscle',
  freqPerWeek: 4,
  plan: [],
  planStartDate: null,
  weights: [],
  measurements: [],
  waterIntake: 0,
  dietMeals: {},
  trainingLog: {},
  settings: { birthYear: 1987, height: 170, weight: 65, goalWeight: 75, gender: 'male' },
};

// ===== Utility =====
function todayStr() {
  var d = new Date();
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}

function showToast(msg) {
  var t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2000);
}

function saveState() {
  try { localStorage.setItem('monsterPlanState', JSON.stringify(state)); } catch(e) {}
}

function loadState() {
  try {
    var s = localStorage.getItem('monsterPlanState');
    if (s) {
      var parsed = JSON.parse(s);
      for (var key in parsed) {
        if (key === 'settings' && parsed.settings) {
          for (var sk in parsed.settings) {
            state.settings[sk] = parsed.settings[sk];
          }
        } else {
          state[key] = parsed[key];
        }
      }
    }
  } catch(e) {}
}

// ===== Onboarding =====
var onboardingSelections = { equip: 'band', goal: 'muscle', freq: 4 };

function initOnboarding() {
  var equipGrid = document.getElementById('onboardingEquipGrid');
  if (!equipGrid) return;
  equipGrid.innerHTML = '';
  var keys = ['band','dumbbell','barbell','bodyweight','kettlebell','mixed'];
  for (var i = 0; i < keys.length; i++) {
    var eq = EQUIPMENT[keys[i]];
    if (!eq) continue;
    var card = document.createElement('div');
    card.className = 'equip-card' + (onboardingSelections.equip === eq.id ? ' selected' : '');
    card.innerHTML = '<div class="equip-icon">' + eq.icon + '</div><div class="equip-name">' + eq.name + '</div>';
    (function(eqId) {
      card.onclick = function() { onboardingSelections.equip = eqId; initOnboarding(); };
    })(eq.id);
    equipGrid.appendChild(card);
  }

  var goalOpt = document.getElementById('onboardingGoalOptions');
  if (goalOpt) {
    goalOpt.innerHTML = '';
    var gKeys = ['muscle','strength','weight_loss','endurance'];
    for (var i = 0; i < gKeys.length; i++) {
      var g = GOALS[gKeys[i]];
      if (!g) continue;
      var card = document.createElement('div');
      card.className = 'goal-card' + (onboardingSelections.goal === g.id ? ' selected' : '');
      card.innerHTML = '<div class="goal-icon">' + g.icon + '</div><div class="goal-text"><h4>' + g.name + '</h4><p>' + g.desc + '</p></div>';
      (function(gId) {
        card.onclick = function() { onboardingSelections.goal = gId; initOnboarding(); };
      })(g.id);
      goalOpt.appendChild(card);
    }
  }

  var freqOpt = document.getElementById('onboardingFreqOptions');
  if (freqOpt) {
    freqOpt.innerHTML = '';
    [3,4,5,6].forEach(function(f) {
      var card = document.createElement('div');
      card.className = 'freq-card' + (onboardingSelections.freq === f ? ' selected' : '');
      card.innerHTML = '<div class="freq-num">' + f + '</div><div class="freq-label">天/周</div>';
      (function(ff) {
        card.onclick = function() { onboardingSelections.freq = ff; initOnboarding(); };
      })(f);
      freqOpt.appendChild(card);
    });
  }
}

function completeOnboarding() {
  state.equipment = onboardingSelections.equip;
  state.goal = onboardingSelections.goal;
  state.freqPerWeek = onboardingSelections.freq;
  state.plan = generatePlan(state.equipment, state.goal, state.freqPerWeek);
  state.planStartDate = todayStr();
  state.onboardingDone = true;
  var h = document.getElementById('onboardingHeight').value;
  var w = document.getElementById('onboardingWeight').value;
  if (h) state.settings.height = parseInt(h) || 170;
  if (w) state.settings.weight = parseFloat(w) || 65;
  saveState();
  initApp();
}

// ===== Init App =====
function initApp() {
  loadState();
  if (!state.onboardingDone) {
    showPage('onboarding');
    initOnboarding();
    return;
  }
  if (!state.plan || state.plan.length === 0) {
    state.plan = generatePlan(state.equipment, state.goal, state.freqPerWeek);
    saveState();
  }
  renderToday();
  renderPlan();
  renderDiet();
  renderData();
  renderStats();
  renderSettings();
  showPage('today');
}

// ===== Page Navigation =====
function showPage(pageId) {
  var pages = document.querySelectorAll('.page');
  for (var i = 0; i < pages.length; i++) pages[i].classList.remove('active');
  var target = document.getElementById('page-' + pageId);
  if (target) target.classList.add('active');
  var navItems = document.querySelectorAll('.nav-item');
  for (var i = 0; i < navItems.length; i++) {
    navItems[i].classList.toggle('active', navItems[i].getAttribute('data-page') === pageId);
  }
  if (pageId === 'today') renderToday();
  if (pageId === 'plan') renderPlan();
  if (pageId === 'diet') renderDiet();
  if (pageId === 'stats') renderStats();
  if (pageId === 'data') renderData();
  if (pageId === 'settings') renderSettings();
}

function switchPage(pageId) { showPage(pageId); }

// ===== Today Page =====
function getTodayPlanDay() {
  if (!state.planStartDate || !state.plan || state.plan.length === 0) return 0;
  var start = new Date(state.planStartDate);
  var now = new Date();
  var diffDays = Math.floor((now - start) / (1000*60*60*24));
  return Math.max(0, diffDays) % state.plan.length;
}

function renderToday() {
  var now = new Date();
  var weekdays = ['周日','周一','周二','周三','周四','周五','周六'];
  var wd = weekdays[now.getDay()];
  var dateStr = now.getFullYear() + '年' + (now.getMonth()+1) + '月' + now.getDate() + '日 ' + wd;
  var el = document.getElementById('todayDate');
  if (el) el.textContent = dateStr;
  var hour = now.getHours();
  var greeting = '晚上好';
  if (hour < 6) greeting = '夜深了';
  else if (hour < 12) greeting = '早上好';
  else if (hour < 14) greeting = '中午好';
  else if (hour < 18) greeting = '下午好';
  var gEl = document.getElementById('todayGreeting');
  if (gEl) gEl.innerHTML = greeting + '，<span>毅</span>';
  var streak = getStreak();
  var streakEl = document.getElementById('todayStreak');
  if (streakEl) {
    if (streak > 0) {
      streakEl.style.display = 'inline-flex';
      streakEl.innerHTML = '🔥 连续打卡 ' + streak + ' 天';
    } else {
      streakEl.style.display = 'none';
    }
  }
  var weekComplete = getWeekCompletedCount();
  var totalComplete = getTotalCompleted();
  var qsEl = document.getElementById('todayQuickStats');
  if (qsEl) {
    qsEl.innerHTML = '<div class="quick-stat"><div class="quick-stat-value">' + weekComplete + '</div><div class="quick-stat-label">本周打卡</div></div>'
      + '<div class="quick-stat"><div class="quick-stat-value">' + totalComplete + '</div><div class="quick-stat-label">总训练次数</div></div>'
      + '<div class="quick-stat"><div class="quick-stat-value">' + (state.settings.weight || '--') + '</div><div class="quick-stat-label">当前体重kg</div></div>';
  }
  var todayKey = todayStr();
  var todayLog = state.trainingLog[todayKey];
  var walkDone = todayLog && todayLog.walk;
  var walkCard = document.getElementById('walkCheckin');
  if (walkCard) walkCard.classList.toggle('done', walkDone);
  var walkBtn = document.getElementById('walkBtn');
  if (walkBtn) { walkBtn.textContent = walkDone ? '✓ 已完成' : '打卡'; walkBtn.classList.toggle('done', walkDone); }
  var dayIdx = getTodayPlanDay();
  var dayPlan = state.plan[dayIdx];
  var titleEl = document.getElementById('todayWorkoutTitle');
  var tagEl = document.getElementById('todayWorkoutTag');
  var startBtn = document.getElementById('startWorkoutBtn');
  var listEl = document.getElementById('todayExerciseList');
  if (!dayPlan) {
    if (titleEl) titleEl.textContent = '暂无计划';
    if (tagEl) { tagEl.textContent = '设置'; tagEl.className = 'today-workout-tag tag-rest'; }
    if (listEl) listEl.innerHTML = '<div style="padding:20px;text-align:center;color:#666;">请先完成设置，生成训练计划</div>';
    if (startBtn) startBtn.style.display = 'none';
    return;
  }
  if (startBtn) startBtn.style.display = 'block';
  if (dayPlan.isRest) {
    if (titleEl) titleEl.textContent = dayPlan.name;
    if (tagEl) { tagEl.textContent = '休息日'; tagEl.className = 'today-workout-tag tag-rest'; }
    if (startBtn) { startBtn.textContent = '🧘 今日休息'; startBtn.className = 'start-workout-btn rest-day'; }
  } else {
    if (titleEl) titleEl.textContent = dayPlan.name;
    if (tagEl) { tagEl.textContent = '训练日'; tagEl.className = 'today-workout-tag tag-training'; }
    if (startBtn) { startBtn.textContent = '开始训练 ⚡'; startBtn.className = 'start-workout-btn'; }
  }
  if (listEl) {
    listEl.innerHTML = '';
    var completedExercises = (todayLog && todayLog.dayIdx === dayIdx && todayLog.exercises) || [];
    for (var i = 0; i < dayPlan.exercises.length; i++) {
      var ex = dayPlan.exercises[i];
      var done = completedExercises[i] === true;
      var item = document.createElement('div');
      item.className = 'today-exercise-item';
      item.innerHTML = '<div class="exercise-checkbox' + (done ? ' checked' : '') + '" onclick="toggleTodayExercise(' + dayIdx + ',' + i + ')"></div>'
        + '<div class="exercise-info"><div class="exercise-name">' + ex.name + '</div>'
        + '<div class="exercise-sets">' + ex.sets + '组 × ' + ex.reps + (typeof ex.reps === 'string' && ex.reps.indexOf('秒') === -1 ? '次' : '') + '（休息' + (ex.rest || 60) + '秒）</div></div>';
      listEl.appendChild(item);
    }
  }
}

function toggleTodayExercise(dayIdx, exIdx) {
  var key = todayStr();
  if (!state.trainingLog[key]) state.trainingLog[key] = { dayIdx: dayIdx, exercises: [], walk: false };
  if (!state.trainingLog[key].exercises) state.trainingLog[key].exercises = [];
  state.trainingLog[key].exercises[exIdx] = !state.trainingLog[key].exercises[exIdx];
  saveState();
  renderToday();
  showToast('打卡更新！');
}

function toggleWalk() {
  var key = todayStr();
  if (!state.trainingLog[key]) state.trainingLog[key] = { dayIdx: getTodayPlanDay(), exercises: [], walk: false };
  state.trainingLog[key].walk = !state.trainingLog[key].walk;
  saveState();
  renderToday();
  showToast(state.trainingLog[key].walk ? '步行打卡完成！+300kcal' : '已取消步行打卡');
}

// ===== Workout Active =====
function startWorkout() {
  var dayIdx = getTodayPlanDay();
  var dayPlan = state.plan[dayIdx];
  if (!dayPlan || dayPlan.isRest) { showToast('今天是休息日，好好恢复！'); return; }
  state.activeDayIdx = dayIdx;
  state.activeExIdx = 0;
  var overlay = document.getElementById('workoutActive');
  if (overlay) overlay.classList.add('active');
  var nav = document.getElementById('bottomNav');
  if (nav) nav.style.display = 'none';
  renderActiveExercise();
  startTimer();
}

function renderActiveExercise() {
  var dayPlan = state.plan[state.activeDayIdx];
  if (!dayPlan || state.activeExIdx >= dayPlan.exercises.length) { completeWorkout(); return; }
  var ex = dayPlan.exercises[state.activeExIdx];
  var nameEl = document.getElementById('activeExName');
  var setsEl = document.getElementById('activeExSets');
  if (nameEl) nameEl.textContent = ex.name;
  if (setsEl) setsEl.textContent = '第 ' + (state.activeExIdx + 1) + ' 个动作 · ' + ex.sets + '组 × ' + ex.reps;
  var total = dayPlan.exercises.length;
  var progText = document.getElementById('workoutProgressText');
  if (progText) progText.textContent = (state.activeExIdx + 1) + ' / ' + total;
  var progFill = document.getElementById('workoutProgressFill');
  if (progFill) progFill.style.width = ((state.activeExIdx) / total * 100) + '%';
  var setBtns = document.getElementById('activeSetBtns');
  if (setBtns) {
    setBtns.innerHTML = '';
    for (var i = 0; i < ex.sets; i++) {
      (function(idx) {
        var btn = document.createElement('div');
        btn.className = 'workout-set-btn';
        btn.textContent = idx + 1;
        btn.onclick = function() { btn.classList.toggle('done'); };
        setBtns.appendChild(btn);
      })(i);
    }
  }
  var nextBtn = document.getElementById('activeNextBtn');
  if (nextBtn) nextBtn.style.display = 'block';
  var completeEl = document.getElementById('workoutComplete');
  if (completeEl) completeEl.classList.remove('active');
}

function nextExercise() {
  var dayPlan = state.plan[state.activeDayIdx];
  var todayKey = todayStr();
  if (!state.trainingLog[todayKey]) state.trainingLog[todayKey] = { dayIdx: state.activeDayIdx, exercises: [], walk: false };
  if (!state.trainingLog[todayKey].exercises) state.trainingLog[todayKey].exercises = [];
  state.trainingLog[todayKey].exercises[state.activeExIdx] = true;
  saveState();
  state.activeExIdx++;
  if (state.activeExIdx >= dayPlan.exercises.length) {
    completeWorkout();
  } else {
    renderActiveExercise();
    resetTimer();
  }
}

function completeWorkout() {
  var completeEl = document.getElementById('workoutComplete');
  if (completeEl) completeEl.classList.add('active');
  var nextBtn = document.getElementById('activeNextBtn');
  if (nextBtn) nextBtn.style.display = 'none';
  clearInterval(state.activeTimerInterval);
  var statsEl = document.getElementById('completeStats');
  if (statsEl) statsEl.textContent = '用时 ' + formatTime(state.activeTimerSec);
}

function exitWorkout() {
  clearInterval(state.activeTimerInterval);
  var overlay = document.getElementById('workoutActive');
  if (overlay) overlay.classList.remove('active');
  var nav = document.getElementById('bottomNav');
  if (nav) nav.style.display = 'flex';
  renderToday();
}

function startTimer() {
  state.activeTimerSec = 0;
  var timerEl = document.getElementById('activeTimer');
  if (timerEl) timerEl.textContent = '00:00';
  clearInterval(state.activeTimerInterval);
  state.activeTimerInterval = setInterval(function() {
    state.activeTimerSec++;
    var m = Math.floor(state.activeTimerSec / 60);
    var s = state.activeTimerSec % 60;
    if (timerEl) timerEl.textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
  }, 1000);
}

function resetTimer() {
  state.activeTimerSec = 0;
  var timerEl = document.getElementById('activeTimer');
  if (timerEl) timerEl.textContent = '00:00';
}

function formatTime(sec) {
  var m = Math.floor(sec / 60);
  var s = sec % 60;
  return String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
}

// ===== Plan Page =====
function renderPlan() {
  var badge = document.getElementById('planEquipBadge');
  if (badge) badge.textContent = (EQUIPMENT[state.equipment] || {}).name || '拉力绳';
  var list = document.getElementById('planDayList');
  if (!list) return;
  list.innerHTML = '';
  if (!state.plan || state.plan.length === 0) {
    list.innerHTML = '<div style="padding:40px;text-align:center;color:#666;">暂无计划，请先在设置中生成</div>';
    return;
  }
  var todayDayIdx = getTodayPlanDay();
  for (var i = 0; i < state.plan.length; i++) {
    var day = state.plan[i];
    var card = document.createElement('div');
    card.className = 'plan-day-card';
    var isToday = (i === todayDayIdx);
    var headerHtml = '<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid #222;cursor:pointer;" onclick="togglePlanDay(' + i + ')">'
      + '<div><div class="plan-day-name' + (day.isRest ? ' plan-day-rest' : '') + '">'
      + (isToday ? '⚡ ' : '') + 'Day ' + (i+1) + ': ' + day.name
      + '</div><div class="plan-day-num">' + day.exercises.length + ' 个动作' + (day.isRest ? ' · 休息日' : '') + '</div></div>'
      + '<div style="color:var(--text-secondary);font-size:12px;" id="planArrow' + i + '">▼</div></div>';
    var exHtml = '<div class="plan-day-exercises" id="planExercises' + i + '">';
    for (var j = 0; j < day.exercises.length; j++) {
      var ex = day.exercises[j];
      exHtml += '<div class="plan-exercise-row"><div class="plan-exercise-idx">' + (j+1) + '</div>'
        + '<div class="plan-exercise-name">' + ex.name + '</div>'
        + '<div class="plan-exercise-sets">' + ex.sets + '×' + ex.reps + '</div></div>';
    }
    exHtml += '</div>';
    card.innerHTML = headerHtml + exHtml;
    if (isToday) card.style.borderColor = 'var(--border-green)';
    list.appendChild(card);
  }
}

function togglePlanDay(i) {
  var el = document.getElementById('planExercises' + i);
  var arrow = document.getElementById('planArrow' + i);
  if (!el) return;
  el.classList.toggle('expanded');
  if (arrow) arrow.textContent = el.classList.contains('expanded') ? '▲' : '▼';
}

// ===== Equip Switch Modal =====
var modalSelections = { equip: 'band', goal: 'muscle' };

function showEquipModal() {
  modalSelections.equip = state.equipment;
  modalSelections.goal = state.goal;
  var grid = document.getElementById('modalEquipGrid');
  if (grid) {
    grid.innerHTML = '';
    var keys = ['band','dumbbell','barbell','bodyweight','kettlebell','mixed'];
    for (var i = 0; i < keys.length; i++) {
      var eq = EQUIPMENT[keys[i]];
      if (!eq) continue;
      var card = document.createElement('div');
      card.className = 'equip-card' + (modalSelections.equip === eq.id ? ' selected' : '');
      card.innerHTML = '<div class="equip-icon">' + eq.icon + '</div><div class="equip-name">' + eq.name + '</div>';
      (function(eqId) {
        card.onclick = function() { modalSelections.equip = eqId; showEquipModal(); };
      })(eq.id);
      grid.appendChild(card);
    }
  }
  selectModalGoal(modalSelections.goal);
  var modal = document.getElementById('equipModal');
  if (modal) modal.classList.add('active');
}

function selectModalGoal(goalId) {
  modalSelections.goal = goalId;
  var btns = document.querySelectorAll('.modal-goal-btn');
  for (var i = 0; i < btns.length; i++) {
    btns[i].style.borderColor = '#333';
    btns[i].style.background = '#1a1a1a';
  }
  var btnMap = { muscle:'modalGoalMuscle', strength:'modalGoalStrength', weight_loss:'modalGoalWeightLoss', endurance:'modalGoalEndurance' };
  var btnId = btnMap[goalId];
  if (btnId) {
    var btn = document.getElementById(btnId);
    if (btn) { btn.style.borderColor = 'var(--text-green)'; btn.style.background = 'rgba(0,255,106,0.1)'; }
  }
}

function applyEquipSwitch() {
  state.equipment = modalSelections.equip;
  state.goal = modalSelections.goal;
  state.plan = generatePlan(state.equipment, state.goal, state.freqPerWeek);
  saveState();
  hideEquipModal();
  renderPlan();
  renderToday();
  showToast('已切换训练方案！');
}

function hideEquipModal() {
  var modal = document.getElementById('equipModal');
  if (modal) modal.classList.remove('active');
}

// ===== Diet Page =====
var FOOD_DB = [
  { name:'鸡胸肉100g', cal:133, protein:31 },
  { name:'鸡蛋1个', cal:70, protein:6 },
  { name:'蛋白粉1勺', cal:120, protein:24 },
  { name:'米饭150g', cal:180, protein:4 },
  { name:'牛肉100g', cal:250, protein:26 },
  { name:'三文鱼100g', cal:208, protein:20 },
  { name:'面包2片', cal:160, protein:6 },
  { name:'牛奶250ml', cal:150, protein:8 },
  { name:'香蕉1根', cal:105, protein:1 },
  { name:'燕麦50g', cal:195, protein:7 },
];

function renderDiet() {
  var dateText = state.dietDate || todayStr();
  var d = new Date(dateText);
  var dateEl = document.getElementById('dietDateText');
  if (dateEl) dateEl.textContent = (d.getMonth()+1) + '月' + d.getDate() + '日';
  var meals = state.dietMeals[dateText] || { breakfast:[], lunch:[], dinner:[], snack:[] };
  var mealNames = { breakfast:'早餐', lunch:'午餐', dinner:'晚餐', snack:'加餐' };
  var mealIcons = { breakfast:'🌅', lunch:'☀️', dinner:'🌙', snack:'🍪' };
  var totalCal = 0, totalProtein = 0;
  var list = document.getElementById('dietMealList');
  if (!list) return;
  list.innerHTML = '';
  var mealKeys = ['breakfast','lunch','dinner','snack'];
  for (var m = 0; m < mealKeys.length; m++) {
    var mealKey = mealKeys[m];
    var section = document.createElement('div');
    section.className = 'diet-meal-section';
    var mealItems = meals[mealKey] || [];
    var mealCal = 0;
    for (var f = 0; f < mealItems.length; f++) {
      mealCal += mealItems[f].cal || 0;
      totalCal += mealItems[f].cal || 0;
      totalProtein += (mealItems[f].protein || 0);
    }
    var expanded = (mealKey === 'breakfast') ? 'block' : 'none';
    var html = '<div class="diet-meal-header" onclick="toggleMealSection(\'' + mealKey + '\')">'
      + '<div><span style="font-size:16px;margin-right:6px;">' + mealIcons[mealKey] + '</span>'
      + '<span class="diet-meal-name">' + mealNames[mealKey] + '</span></div>'
      + '<div class="diet-meal-cal">' + mealCal + ' kcal</div></div>';
    html += '<div id="mealSection_' + mealKey + '" style="display:' + expanded + ';">';
    for (var f = 0; f < mealItems.length; f++) {
      var food = mealItems[f];
      html += '<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1a1a1a;font-size:13px;">'
        + '<span>' + food.name + '</span><span style="color:var(--text-green);">' + food.cal + ' kcal</span></div>';
    }
    html += '<div class="diet-meal-add" onclick="showAddFoodDialog(\'' + mealKey + '\')">+ 添加食物</div>';
    html += '</div>';
    section.innerHTML = html;
    list.appendChild(section);
  }
  var quickList = document.getElementById('quickFoodList');
  if (quickList) {
    quickList.innerHTML = '';
    for (var f = 0; f < FOOD_DB.length; f++) {
      (function(food) {
        var btn = document.createElement('button');
        btn.className = 'quick-food-btn';
        btn.textContent = food.name;
        btn.onclick = function() { addFood('lunch', food); };
        quickList.appendChild(btn);
      })(FOOD_DB[f]);
    }
  }
  var bmr = calcBMR();
  var tdee = calcTDEE();
  var recommended = (state.goal === 'weight_loss') ? tdee - 300 : tdee + 300;
  var calText = document.getElementById('dietCalText');
  if (calText) calText.textContent = totalCal + ' / ' + recommended + ' kcal';
  var intakeText = document.getElementById('dietIntakeText');
  if (intakeText) intakeText.textContent = '摄入: ' + totalCal + ' kcal';
  var burnText = document.getElementById('dietBurnText');
  if (burnText) burnText.textContent = '消耗: ~' + tdee + ' kcal';
  var fill = document.getElementById('dietCalFill');
  if (fill) {
    var pct = Math.min(100, (totalCal / recommended) * 100);
    fill.style.width = pct + '%';
    fill.className = 'diet-cal-fill' + (totalCal > recommended + 200 ? ' surplus' : ' deficit');
  }
}

function addFood(mealKey, food) {
  var dateKey = state.dietDate || todayStr();
  if (!state.dietMeals[dateKey]) state.dietMeals[dateKey] = { breakfast:[], lunch:[], dinner:[], snack:[] };
  if (!state.dietMeals[dateKey][mealKey]) state.dietMeals[dateKey][mealKey] = [];
  state.dietMeals[dateKey][mealKey].push(food);
  saveState();
  renderDiet();
  showToast('已添加 ' + food.name);
}

function showAddFoodDialog(mealKey) {
  var foodName = prompt('输入食物名称：');
  if (!foodName) return;
  var cal = parseInt(prompt('热量（kcal）：')) || 0;
  var protein = parseInt(prompt('蛋白质（g，选填）：')) || 0;
  addFood(mealKey, { name: foodName, cal: cal, protein: protein });
}

function toggleMealSection(mealKey) {
  var el = document.getElementById('mealSection_' + mealKey);
  if (el) el.style.display = (el.style.display === 'none') ? 'block' : 'none';
}

function changeDietDate(delta) {
  var d = new Date(state.dietDate || todayStr());
  d.setDate(d.getDate() + delta);
  state.dietDate = d.toISOString().split('T')[0];
  renderDiet();
}

// ===== Data Page =====
function renderData() {
  var canvas = document.getElementById('weightChart');
  if (canvas && state.weights && state.weights.length > 0) {
    drawWeightChart(canvas, state.weights);
  }
  var todayKey = todayStr();
  var todayData = (state.dietMeals[todayKey] && state.dietMeals[todayKey].water) || 0;
  state.waterIntake = todayData;
  var waterEl = document.getElementById('waterAmount');
  if (waterEl) waterEl.textContent = state.waterIntake;
}

function addWeight() {
  var val = parseFloat(document.getElementById('weightInput').value);
  if (!val || val <= 0) { showToast('请输入有效体重'); return; }
  var todayKey = todayStr();
  state.weights = (state.weights || []).filter(function(w) { return w.date !== todayKey; });
  state.weights.push({ date: todayKey, value: val });
  state.weights.sort(function(a, b) { return a.date.localeCompare(b.date); });
  state.settings.weight = val;
  saveState();
  var input = document.getElementById('weightInput');
  if (input) input.value = '';
  renderData();
  renderToday();
  showToast('体重 ' + val + 'kg 已记录！');
}

function addMeasurement() {
  var todayKey = todayStr();
  var m = {
    date: todayKey,
    chest: parseFloat(document.getElementById('chestInput').value) || null,
    arm: parseFloat(document.getElementById('armInput').value) || null,
    waist: parseFloat(document.getElementById('waistInput').value) || null,
    thigh: parseFloat(document.getElementById('thighInput').value) || null,
  };
  state.measurements = (state.measurements || []).filter(function(x) { return x.date !== todayKey; });
  state.measurements.push(m);
  state.measurements.sort(function(a, b) { return a.date.localeCompare(b.date); });
  saveState();
  showToast('围度已记录！');
}

function addWater(amount) {
  var todayKey = todayStr();
  if (!state.dietMeals[todayKey]) state.dietMeals[todayKey] = { breakfast:[], lunch:[], dinner:[], snack:[], water:0 };
  state.dietMeals[todayKey].water = (state.dietMeals[todayKey].water || 0) + amount;
  state.waterIntake = state.dietMeals[todayKey].water;
  saveState();
  renderData();
  showToast('+' + amount + 'ml 饮水已记录');
}

// ===== Simple Canvas Chart =====
function drawWeightChart(canvas, weights) {
  if (!canvas || !weights || weights.length < 1) return;
  var ctx = canvas.getContext('2d');
  var rect = canvas.parentElement ? canvas.parentElement.getBoundingClientRect() : { width: 300, height: 200 };
  var w = rect.width || 300;
  var h = 200;
  canvas.width = w * 2;
  canvas.height = h * 2;
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';
  ctx.scale(2, 2);
  var padding = { top: 20, right: 10, bottom: 30, left: 35 };
  var chartW = w - padding.left - padding.right;
  var chartH = h - padding.top - padding.bottom;
  ctx.clearRect(0, 0, w, h);
  var values = weights.map(function(x) { return x.value; });
  var minV = Math.min.apply(null, values) - 1;
  var maxV = Math.max.apply(null, values) + 1;
  var rangeV = maxV - minV || 1;
  ctx.strokeStyle = '#333';
  ctx.lineWidth = 0.5;
  for (var i = 0; i <= 4; i++) {
    var y = padding.top + (chartH * i / 4);
    ctx.beginPath();
    ctx.moveTo(padding.left, y);
    ctx.lineTo(w - padding.right, y);
    ctx.stroke();
    ctx.fillStyle = '#888';
    ctx.font = '10px sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText((maxV - rangeV * i / 4).toFixed(1), padding.left - 5, y + 3);
  }
  ctx.beginPath();
  ctx.strokeStyle = '#00ff6a';
  ctx.lineWidth = 2;
  ctx.shadowColor = 'rgba(0,255,106,0.5)';
  ctx.shadowBlur = 6;
  for (var i = 0; i < weights.length; i++) {
    var x = padding.left + (i / Math.max(1, weights.length - 1)) * chartW;
    var y = padding.top + chartH * (1 - (weights[i].value - minV) / rangeV);
    if (i === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  }
  ctx.stroke();
  ctx.shadowBlur = 0;
  for (var i = 0; i < weights.length; i++) {
    var x = padding.left + (i / Math.max(1, weights.length - 1)) * chartW;
    var y = padding.top + chartH * (1 - (weights[i].value - minV) / rangeV);
    ctx.beginPath();
    ctx.arc(x, y, 3, 0, Math.PI * 2);
    ctx.fillStyle = '#00ff6a';
    ctx.fill();
  }
  if (state.settings.goalWeight) {
    var goalY = padding.top + chartH * (1 - (state.settings.goalWeight - minV) / rangeV);
    if (goalY >= padding.top && goalY <= padding.top + chartH) {
      ctx.strokeStyle = '#ff6a00';
      ctx.lineWidth = 1;
      ctx.setLineDash([5, 3]);
      ctx.beginPath();
      ctx.moveTo(padding.left, goalY);
      ctx.lineTo(w - padding.right, goalY);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = '#ff6a00';
      ctx.font = '10px sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText('目标 ' + state.settings.goalWeight + 'kg', padding.left + 5, goalY - 5);
    }
  }
  ctx.fillStyle = '#888';
  ctx.font = '9px sans-serif';
  ctx.textAlign = 'center';
  for (var i = 0; i < weights.length; i++) {
    if (i % Math.ceil(weights.length / 5) === 0 || i === weights.length - 1) {
      var x = padding.left + (i / Math.max(1, weights.length - 1)) * chartW;
      ctx.fillText(weights[i].date.slice(5), x, h - 5);
    }
  }
}

// ===== Stats Page =====
function renderStats() {
  var streak = getStreak();
  var total = getTotalCompleted();
  var streakEl = document.getElementById('statsStreak');
  if (streakEl) streakEl.textContent = streak;
  var totalEl = document.getElementById('statsTotal');
  if (totalEl) totalEl.textContent = total;
  var weekComplete = getWeekCompletedCount();
  var weekRate = Math.round((weekComplete / Math.min(7, (state.plan || []).length || 1)) * 100);
  var weekRateEl = document.getElementById('statsWeekRate');
  if (weekRateEl) weekRateEl.textContent = weekRate + '%';
  var monthComplete = getMonthCompletedCount();
  var monthRateVal = Math.round((monthComplete / Math.min(30, ((state.plan || []).length || 1) * 4)) * 100);
  var monthRateEl = document.getElementById('statsMonthRate');
  if (monthRateEl) monthRateEl.textContent = monthRateVal + '%';
  if (state.weights && state.weights.length >= 2) {
    var first = state.weights[0].value;
    var last = state.weights[state.weights.length - 1].value;
    var change = (last - first).toFixed(1);
    var changeEl = document.getElementById('statsWeightChange');
    if (changeEl) {
      changeEl.textContent = (change >= 0 ? '+' : '') + change + 'kg';
      changeEl.style.color = change > 0 ? '#ff6a00' : '#00ff6a';
    }
  }
  var weekGrid = document.getElementById('statsWeekGrid');
  if (weekGrid) {
    weekGrid.innerHTML = '';
    var weekDays = ['日','一','二','三','四','五','六'];
    for (var i = 0; i < 7; i++) {
      var d = new Date();
      d.setDate(d.getDate() - d.getDay() + i);
      var key = d.toISOString().split('T')[0];
      var hasLog = state.trainingLog[key] && state.trainingLog[key].exercises && state.trainingLog[key].exercises.some(function(e) { return e; });
      var cell = document.createElement('div');
      cell.style.cssText = 'aspect-ratio:1;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-direction:column;gap:2px;'
        + 'background:' + (hasLog ? 'rgba(0,255,106,0.15)' : '#1a1a1a') + ';'
        + 'border:1px solid ' + (hasLog ? 'rgba(0,255,106,0.3)' : '#333') + ';'
        + 'color:' + (hasLog ? 'var(--text-green)' : '#666') + ';';
      cell.innerHTML = '<div style="font-size:10px;color:#888;">' + weekDays[i] + '</div><div>' + (hasLog ? '✓' : '—') + '</div>';
      weekGrid.appendChild(cell);
    }
  }
}

// ===== Helpers =====
function getStreak() {
  var streak = 0;
  var d = new Date();
  while (true) {
    var key = d.toISOString().split('T')[0];
    var log = state.trainingLog[key];
    if (log && log.exercises && log.exercises.some(function(e) { return e; })) {
      streak++;
      d.setDate(d.getDate() - 1);
    } else {
      break;
    }
  }
  return streak;
}

function getTotalCompleted() {
  return Object.keys(state.trainingLog).filter(function(key) {
    var l = state.trainingLog[key];
    return l && l.exercises && l.exercises.some(function(e) { return e; });
  }).length;
}

function getWeekCompletedCount() {
  var count = 0;
  var d = new Date();
  d.setDate(d.getDate() - d.getDay());
  for (var i = 0; i < 7; i++) {
    var key = d.toISOString().split('T')[0];
    var log = state.trainingLog[key];
    if (log && log.exercises && log.exercises.some(function(e) { return e; })) count++;
    d.setDate(d.getDate() + 1);
  }
  return count;
}

function getMonthCompletedCount() {
  var count = 0;
  var now = new Date();
  var year = now.getFullYear();
  var month = now.getMonth();
  var keys = Object.keys(state.trainingLog);
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    var d2 = new Date(key);
    if (d2.getFullYear() === year && d2.getMonth() === month) {
      var log = state.trainingLog[key];
      if (log && log.exercises && log.exercises.some(function(e) { return e; })) count++;
    }
  }
  return count;
}

function calcBMR() {
  var settings = state.settings || {};
  var birthYear = settings.birthYear || 1987;
  var age = new Date().getFullYear() - birthYear;
  var height = settings.height || 170;
  var weight = settings.weight || 65;
  var gender = settings.gender || 'male';
  if (gender === 'male') {
    return Math.round(10 * weight + 6.25 * height - 5 * age + 5);
  } else {
    return Math.round(10 * weight + 6.25 * height - 5 * age - 161);
  }
}

function calcTDEE() {
  return Math.round(calcBMR() * 1.5) + 300;
}

// ===== Settings =====
function renderSettings() {
  var el;
  el = document.getElementById('settingBirthYear'); if (el) el.value = (state.settings || {}).birthYear || '';
  el = document.getElementById('settingHeight');    if (el) el.value = (state.settings || {}).height || '';
  el = document.getElementById('settingWeight');    if (el) el.value = (state.settings || {}).weight || '';
  el = document.getElementById('settingGoalWeight'); if (el) el.value = (state.settings || {}).goalWeight || '';
  el = document.getElementById('settingEquip');    if (el) el.textContent = (EQUIPMENT[state.equipment] || {}).name || '';
  el = document.getElementById('settingGoal');      if (el) el.textContent = (GOALS[state.goal] || {}).name || '';
  setGender((state.settings || {}).gender || 'male');
}

function setGender(g) {
  state.settings.gender = g;
  var btnM = document.getElementById('genderMale');
  var btnF = document.getElementById('genderFemale');
  if (btnM) {
    btnM.style.borderColor = (g === 'male') ? 'var(--text-green)' : '#333';
    btnM.style.background = (g === 'male') ? 'rgba(0,255,106,0.1)' : '#1a1a1a';
  }
  if (btnF) {
    btnF.style.borderColor = (g === 'female') ? 'var(--text-green)' : '#333';
    btnF.style.background = (g === 'female') ? 'rgba(0,255,106,0.1)' : '#1a1a1a';
  }
  saveState();
}

function saveSettings() {
  var el;
  el = document.getElementById('settingBirthYear');  if (el) state.settings.birthYear = parseInt(el.value) || 1987;
  el = document.getElementById('settingHeight');     if (el) state.settings.height = parseInt(el.value) || 170;
  el = document.getElementById('settingWeight');     if (el) state.settings.weight = parseFloat(el.value) || 65;
  el = document.getElementById('settingGoalWeight'); if (el) state.settings.goalWeight = parseFloat(el.value) || 75;
  saveState();
  showToast('设置已保存！');
}

// ===== Data Export / Reset =====
function exportData() {
  var data = { state: state, exportDate: todayStr(), version:'3.0' };
  var blob = new Blob([JSON.stringify(data, null, 2)], { type:'application/json' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = '怪兽训练备份_' + todayStr() + '.json';
  a.click();
  URL.revokeObjectURL(url);
  showToast('数据已导出！');
}

function resetData() {
  if (confirm('确定要重置所有数据吗？此操作不可撤销！')) {
    localStorage.removeItem('monsterPlanState');
    location.reload();
  }
}

// ===== PWA =====
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(function() {});
}

// ===== Start =====
document.addEventListener('DOMContentLoaded', function() {
  initApp();
  ['settingBirthYear','settingHeight','settingWeight','settingGoalWeight'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('change', saveSettings);
  });
});
</script>
</body>
</html>
